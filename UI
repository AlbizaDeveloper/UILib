                BackgroundTransparency = 1, Text = sc.Title, TextColor3 = T.Text,
                TextSize = 14, Font = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
            })
            local valLbl = New("TextLabel", {
                Parent = elem, Size = UDim2.new(0,70,0,20), Position = UDim2.new(1,-78,0,8),
                BackgroundTransparency = 1, Text = tostring(val)..sc.Suffix,
                TextColor3 = T.Accent, TextSize = 14, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 6,
            })
            if sc.Desc ~= "" then
                New("TextLabel", {
                    Parent = elem, Size = UDim2.new(1,-22,0,14), Position = UDim2.new(0,12,0,28),
                    BackgroundTransparency = 1, Text = sc.Desc, TextColor3 = T.TextMute,
                    TextSize = 11, Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
                })
            end
            local track = New("Frame", {
                Parent = elem, Size = UDim2.new(1,-24,0,6),
                Position = UDim2.new(0,12,1,-18),
                BackgroundColor3 = T.SliderBG, BorderSizePixel = 0, ZIndex = 6,
            })
            AddCorner(track, 1, 0)
            local fill = New("Frame", {
                Parent = track, Size = UDim2.new(0,0,1,0),
                BackgroundColor3 = T.Accent, BorderSizePixel = 0, ZIndex = 7,
            })
            AddCorner(fill, 1, 0); AddGrad(fill, T.AccentDark, T.AccentGlow, 90)
            local knob = New("Frame", {
                Parent = track, Size = UDim2.new(0,16,0,16),
                Position = UDim2.new(0,-8,0.5,-8),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel = 0, ZIndex = 8,
            })
            AddCorner(knob, 1, 0)
            local dot = New("Frame", {
                Parent = knob, Size = UDim2.new(0.5,0,0.5,0),
                Position = UDim2.new(0.25,0,0.25,0),
                BackgroundColor3 = T.Accent, BorderSizePixel = 0, ZIndex = 9,
            })
            AddCorner(dot, 1, 0)
            local hit = New("TextButton", {
                Parent = track, Size = UDim2.new(1,16,0,28),
                Position = UDim2.new(0,-8,0.5,-14),
                BackgroundTransparency = 1, Text = "", ZIndex = 10,
            })
            local function V2S(v) return (v-sc.Min)/(sc.Max-sc.Min) end
            local function S2V(s)
                local raw = sc.Min + s*(sc.Max-sc.Min)
                return math.clamp(math.round(raw/sc.Increment)*sc.Increment, sc.Min, sc.Max)
            end
            local function Render(v)
                val = v
                local s = V2S(v)
                fill.Size = UDim2.new(s,0,1,0)
                knob.Position = UDim2.new(s,-8,0.5,-8)
                valLbl.Text = tostring(v)..sc.Suffix
            end
            Render(val)
            local drag = false
            hit.MouseButton1Down:Connect(function() drag = true end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 and drag then
                    drag = false; task.spawn(sc.Callback, val)
                end
            end)
            RunService.Heartbeat:Connect(function()
                if not drag then return end
                local mx = UserInputService:GetMouseLocation().X
                local s = math.clamp((mx - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                local nv = S2V(s)
                if nv ~= val then Render(nv) end
            end)
            local A = {}
            function A:Set(v) v = math.clamp(v,sc.Min,sc.Max); Render(v); task.spawn(sc.Callback,v) end
            function A:Get() return val end
            return A
        end

