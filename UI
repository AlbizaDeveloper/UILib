            })
            AddCorner(picker, 0, 8); AddStroke(picker, T.BorderAcc)
            New("UIPadding", { Parent = picker, PaddingTop = UDim.new(0,8), PaddingLeft = UDim.new(0,8), PaddingRight = UDim.new(0,8) })

            local function UpdateColor()
                color = Color3.fromRGB(r, g, b)
                prev.BackgroundColor3 = color
                task.spawn(cc.Callback, color)
            end
            local function ChanSlider(ch, yp, dv, mc, ac, cb2)
                New("TextLabel", {
                    Parent = picker, Size = UDim2.new(0,14,0,17), Position = UDim2.new(0,5,0,yp),
                    BackgroundTransparency = 1, Text = ch, TextColor3 = ac,
                    TextSize = 11, Font = Enum.Font.GothamBold, ZIndex = 31,
                })
                local tr = New("Frame", {
                    Parent = picker, Size = UDim2.new(1,-50,0,5),
                    Position = UDim2.new(0,26,0,yp+6),
                    BackgroundColor3 = T.SliderBG, BorderSizePixel = 0, ZIndex = 31,
                })
                AddCorner(tr, 1, 0)
                local fl = New("Frame", {
                    Parent = tr, Size = UDim2.new(dv/mc,0,1,0),
                    BackgroundColor3 = ac, BorderSizePixel = 0, ZIndex = 32,
                })
                AddCorner(fl, 1, 0)
                local kn = New("Frame", {
                    Parent = tr, Size = UDim2.new(0,11,0,11),
                    Position = UDim2.new(dv/mc,-5,0.5,-5),
                    BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 33,
                })
                AddCorner(kn, 1, 0)
                local vl = New("TextLabel", {
                    Parent = picker, Size = UDim2.new(0,20,0,17), Position = UDim2.new(1,-22,0,yp),
                    BackgroundTransparency = 1, Text = tostring(dv), TextColor3 = ac,
                    TextSize = 10, Font = Enum.Font.GothamBold, ZIndex = 31,
                })
                local d2 = false
                local hb = New("TextButton", {
                    Parent = tr, Size = UDim2.new(1,11,0,22),
                    Position = UDim2.new(0,-5,0.5,-11),
                    BackgroundTransparency = 1, Text = "", ZIndex = 34,
                })
                hb.MouseButton1Down:Connect(function() d2 = true end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then d2 = false end
                end)
                RunService.Heartbeat:Connect(function()
                    if not d2 then return end
                    local mx2 = UserInputService:GetMouseLocation().X
                    local s2 = math.clamp((mx2 - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
                    local nv2 = math.round(s2 * mc)
                    fl.Size = UDim2.new(s2,0,1,0); kn.Position = UDim2.new(s2,-5,0.5,-5)
                    vl.Text = tostring(nv2); cb2(nv2)
                end)
            end
            ChanSlider("R", 8,  r, 255, Color3.fromRGB(220,70,70),  function(v) r=v; UpdateColor() end)
            ChanSlider("G", 36, g, 255, Color3.fromRGB(60,200,80),  function(v) g=v; UpdateColor() end)
            ChanSlider("B", 64, b, 255, Color3.fromRGB(70,120,220), function(v) b=v; UpdateColor() end)
            prev.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(picker, TweenInfo.new(isOpen and 0.24 or 0.17, Enum.EasingStyle.Quart),
                    { Size = UDim2.new(0,210,0, isOpen and 100 or 0) })
            end)
            local A = {}
            function A:Set(c3) color = c3; prev.BackgroundColor3 = c3 end
            function A:Get()   return color end
            return A
        end

        return Tab
    end -- AddTab

    -- Show window
    if wc.IntroEnabled then
        main.Visible = false
        task.spawn(function()
            PlayIntro(wc.IntroText, function()
                main.Visible = true
                Tween(main, TweenInfo.new(0.42, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                    { BackgroundTransparency = 0 })
            end)
        end)
    else
        Tween(main, TweenInfo.new(0.38, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { BackgroundTransparency = 0 })
    end

    return Win
end

function Lib:SetTheme(t2) for k, v in pairs(t2) do T[k] = v end end
function Lib:GetTheme()   return T end

return setmetatable(Lib, Lib)
