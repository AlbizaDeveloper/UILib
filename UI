    -- ─ Notify ────────────────────────────────────────────────────────────
    function Win:Notify(c)
        c = c or {}
        local nc = {
            Title    = c.Title    or "Notification",
            Content  = c.Content  or "",
            Duration = c.Duration or 4,
            Type     = c.Type     or "Info",
        }
        local colors = {
            Info    = Color3.fromRGB(55,100,220),
            Success = Color3.fromRGB(40,185,75),
            Warning = Color3.fromRGB(220,160,28),
            Error   = T.Accent,
        }
        local ac = colors[nc.Type] or colors.Info

        local notif = New("Frame", {
            Parent = notifHolder, Size = UDim2.new(1,0,0,72),
            BackgroundColor3 = T.Surface, BackgroundTransparency = 0.04,
            BorderSizePixel = 0, ZIndex = 201, ClipsDescendants = true,
            Position = UDim2.new(1.15,0,0,0),
        })
        AddCorner(notif, 0, 8); AddStroke(notif, T.Border, 1)
        New("Frame", { Parent = notif, Size = UDim2.new(0,3,1,0), BackgroundColor3 = ac, BorderSizePixel = 0, ZIndex = 202 })
        New("TextLabel", {
            Parent = notif, Size = UDim2.new(1,-18,0,22), Position = UDim2.new(0,14,0,10),
            BackgroundTransparency = 1, Text = nc.Title, TextColor3 = T.Text,
            TextSize = 14, Font = Enum.Font.GothamBold, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 202,
        })
        New("TextLabel", {
            Parent = notif, Size = UDim2.new(1,-18,0,32), Position = UDim2.new(0,14,0,33),
            BackgroundTransparency = 1, Text = nc.Content, TextColor3 = T.TextSub,
            TextSize = 12, Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true, ZIndex = 202,
        })
        Tween(notif, TweenInfo.new(0.38, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2.new(0,0,0,0) })
        task.delay(nc.Duration, function()
            Tween(notif, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
                { Position = UDim2.new(1.15,0,0,0) })
            task.wait(0.38); notif:Destroy()
        end)
    end

    -- ─ AddTab ─────────────────────────────────────────────────────────────
    function Win:AddTab(c)
        c = c or {}
        tabOrder = tabOrder + 1
        local title = c.Title or ("Tab "..tabOrder)

        -- Sidebar button
        local tabBtn = New("TextButton", {
            Parent = sidebar, Size = UDim2.new(1,0,0,36),
            BackgroundColor3 = T.SurfaceAlt, BackgroundTransparency = 1,
            Text = "", BorderSizePixel = 0, ZIndex = 6, LayoutOrder = tabOrder,
        })
        AddCorner(tabBtn, 0, 7)
        local indicator = New("Frame", {
            Parent = tabBtn, Size = UDim2.new(0,3,0.55,0),
            Position = UDim2.new(0,0,0.225,0),
            BackgroundColor3 = T.Accent, BackgroundTransparency = 1,
            BorderSizePixel = 0, ZIndex = 7,
        })
        AddCorner(indicator, 1, 0)
        local tabLbl = New("TextLabel", {
            Parent = tabBtn, Size = UDim2.new(1,-12,1,0),
            Position = UDim2.new(0,12,0,0),
            BackgroundTransparency = 1, Text = title,
            TextColor3 = T.TextMute, TextSize = 13, Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7,
        })

        -- Page
        local page = New("ScrollingFrame", {
            Parent = content, Size = UDim2.new(1,0,1,0),
            BackgroundTransparency = 1, BorderSizePixel = 0,
            ScrollBarThickness = 3, ScrollBarImageColor3 = T.Accent,
            CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false, ZIndex = 4,
        })
        New("UIListLayout", { Parent = page, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,6) })
        New("UIPadding", {
            Parent = page,
            PaddingTop = UDim.new(0,12), PaddingLeft = UDim.new(0,12),
            PaddingRight = UDim.new(0,14), PaddingBottom = UDim.new(0,12),
        })

        local td = { btn = tabBtn, ind = indicator, lbl = tabLbl, page = page }
        table.insert(tabs, td)

        local function Select()
            for _, t in ipairs(tabs) do
                t.page.Visible = false
                Tween(t.btn, TweenInfo.new(0.17), { BackgroundTransparency = 1 })
                Tween(t.ind, TweenInfo.new(0.17), { BackgroundTransparency = 1 })
                Tween(t.lbl, TweenInfo.new(0.17), { TextColor3 = T.TextMute })
            end
            td.page.Visible = true; activeTab = td
            Tween(tabBtn,    TweenInfo.new(0.17), { BackgroundTransparency = 0.72 })
            Tween(indicator, TweenInfo.new(0.17), { BackgroundTransparency = 0 })
            Tween(tabLbl,    TweenInfo.new(0.17), { TextColor3 = T.Text })
        end
        tabBtn.MouseButton1Click:Connect(Select)
        tabBtn.MouseEnter:Connect(function()
            if activeTab ~= td then Tween(tabBtn, TweenInfo.new(0.12), { BackgroundTransparency = 0.86 }) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if activeTab ~= td then Tween(tabBtn, TweenInfo.new(0.12), { BackgroundTransparency = 1 }) end
        end)
