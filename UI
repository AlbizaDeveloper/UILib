-- ── Snow ──────────────────────────────────────────────────────────────────
local function CreateSnow(parent, count)
    local flakes = {}
    for i = 1, (count or 50) do
        local sz = math.random(2, 5)
        local f  = New("Frame", {
            Parent                 = parent,
            Size                   = UDim2.new(0, sz, 0, sz),
            Position               = UDim2.new(math.random(), 0, math.random(-20,0)/100, 0),
            BackgroundColor3       = T.Snow,
            BackgroundTransparency = math.random(35, 75)/100,
            BorderSizePixel        = 0,
            ZIndex                 = 2,
        })
        AddCorner(f, 1, 0)
        flakes[i] = {
            frame = f,
            speed = math.random(35, 110)/1000,
            drift = math.random(-25, 25)/1000,
            y     = math.random(-20, 0)/100,
        }
    end
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not parent.Parent then conn:Disconnect(); return end
        for _, s in ipairs(flakes) do
            s.y = s.y + s.speed * dt
            local x = s.frame.Position.X.Scale + s.drift * dt
            if x < -0.05 then x = 1.05 end
            if x >  1.05 then x = -0.05 end
            if s.y > 1.06 then s.y = -0.08; x = math.random() end
            s.frame.Position = UDim2.new(x, 0, s.y, 0)
        end
    end)
    return conn
end

-- ── Intro ─────────────────────────────────────────────────────────────────
local function PlayIntro(text, cb)
    local sg = New("ScreenGui", {
        Name           = "AlbizaIntro",
        Parent         = targetGuiParent,
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 100,
    })
