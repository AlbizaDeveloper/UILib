                Parent = elem, Size = UDim2.new(1,-24,0,0),
                Position = UDim2.new(0,12,1,4),
                BackgroundColor3 = T.DropBG, BorderSizePixel = 0,
                ZIndex = 20, ClipsDescendants = true,
            })
            AddCorner(list, 0, 6); AddStroke(list, T.BorderAcc)
            New("UIListLayout", { Parent = list, SortOrder = Enum.SortOrder.LayoutOrder })
            New("UIPadding", { Parent = list, PaddingTop = UDim.new(0,3), PaddingBottom = UDim.new(0,3) })

            local optBtns = {}
            local totalH  = 0
            local function BuildOptions(opts)
                for _, b in ipairs(optBtns) do b:Destroy() end
                optBtns = {}
                for i, opt in ipairs(opts) do
                    local ob = New("TextButton", {
                        Parent = list, Size = UDim2.new(1,0,0,30),
                        BackgroundTransparency = 1, BackgroundColor3 = T.DropBG,
                        Text = opt, TextColor3 = T.TextSub,
                        TextSize = 13, Font = Enum.Font.Gotham,
                        ZIndex = 21, LayoutOrder = i,
                    })
                    New("UIPadding", { Parent = ob, PaddingLeft = UDim.new(0,10) })
                    ob.TextXAlignment = Enum.TextXAlignment.Left
                    ob.MouseEnter:Connect(function() Tween(ob, TweenInfo.new(0.1), { BackgroundTransparency = 0.7, TextColor3 = T.Text }) end)
                    ob.MouseLeave:Connect(function() Tween(ob, TweenInfo.new(0.1), { BackgroundTransparency = 1,   TextColor3 = T.TextSub }) end)
                    ob.MouseButton1Click:Connect(function()
                        sel = opt; dLbl.Text = opt; isOpen = false
                        Tween(list,  TweenInfo.new(0.18, Enum.EasingStyle.Quart), { Size = UDim2.new(1,-24,0,0) })
                        Tween(elSt,  TweenInfo.new(0.16), { Color = T.Border })
                        arw.Text = "▼"; task.spawn(dc.Callback, opt)
                    end)
                    table.insert(optBtns, ob)
                end
                totalH = #opts * 30 + 6
            end
            BuildOptions(dc.Options)

            dBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Tween(list,  TweenInfo.new(0.22, Enum.EasingStyle.Quart), { Size = UDim2.new(1,-24,0, math.min(totalH,150)) })
                    Tween(elSt,  TweenInfo.new(0.16), { Color = T.BorderAcc })
                    arw.Text = "▲"
                else
                    Tween(list,  TweenInfo.new(0.18, Enum.EasingStyle.Quart), { Size = UDim2.new(1,-24,0,0) })
                    Tween(elSt,  TweenInfo.new(0.16), { Color = T.Border })
                    arw.Text = "▼"
                end
            end)

            local A = {}
            function A:Set(opt)  sel = opt; dLbl.Text = opt end
            function A:Get()     return sel end
            function A:Refresh(o) dc.Options = o; BuildOptions(o) end
            return A
        end

