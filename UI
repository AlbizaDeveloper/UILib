local RunService       = game:GetService("RunService")
local LocalPlayer      = Players.LocalPlayer

local CoreGui
pcall(function() CoreGui = game:GetService("CoreGui") end)

local targetGuiParent
local ok, res = pcall(function() return gethui() end)
if ok and res then
    targetGuiParent = res
elseif CoreGui then
    local ok2 = pcall(function()
        local f = Instance.new("Folder"); f.Parent = CoreGui; f:Destroy()
    end)
    if ok2 then targetGuiParent = CoreGui end
end
if not targetGuiParent then
    targetGuiParent = LocalPlayer:WaitForChild("PlayerGui")
end

local function Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props); t:Play(); return t
end

local function New(class, props)
    local i = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then i[k] = v end
    end
    if props.Parent then i.Parent = props.Parent end
    return i
end

local function Corner(f, radius)
    return New("UICorner", { Parent = f, CornerRadius = UDim.new(0, radius or 8) })
end

local function Stroke(f, col, th)
    return New("UIStroke", { Parent = f, Color = col, Thickness = th or 1 })
end

local function Grad(f, c1, c2, rot)
    return New("UIGradient", { Parent = f, Color = ColorSequence.new(c1, c2), Rotation = rot or 135 })
end

local function Drag(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPos = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
end

