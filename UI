local function PlayIntro(text, cb)
    local sg = New("ScreenGui", {
        Name = "AlbizaIntro", Parent = targetGuiParent,
        ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, DisplayOrder = 100,
    })
    
    local bg = New("Frame", {
        Parent = sg, Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = Color3.fromRGB(0,0,0), BackgroundTransparency = 1, ZIndex = 100,
    })
    
    local txt = New("TextLabel", {
        Parent = bg, Size = UDim2.new(1,0,1,0), Position = UDim2.new(0.5,0,0.5,0),
        AnchorPoint = Vector2.new(0.5,0.5), BackgroundTransparency = 1,
        Text = text or "Albiza Hub", TextColor3 = T.Accent, TextSize = 250,
        Font = Enum.Font.BuilderSansExtraBold, TextTransparency = 1, ZIndex = 101,
    })

    Tween(bg, TweenInfo.new(0.55, Enum.EasingStyle.Quint), { BackgroundTransparency = 0.4 })
    task.wait(0.5)

    Tween(txt, TweenInfo.new(0.75, Enum.EasingStyle.Quint), { TextSize = 45, TextTransparency = 0 })
    task.wait(1.5)

    Tween(txt, TweenInfo.new(0.75, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), { TextSize = 250, TextTransparency = 1 })
    Tween(bg, TweenInfo.new(1.5, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), { BackgroundTransparency = 1 })
    
    task.wait(0.6)
    if cb then cb() end

    task.wait(0.9)
    sg:Destroy()
end

