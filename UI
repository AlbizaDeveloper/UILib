                local hb = New("TextButton", { Parent = tr, Size = UDim2.new(1,11,0,22), Position = UDim2.new(0,-5,0.5,-11), BackgroundTransparency = 1, Text = "", ZIndex = 34 })
                hb.MouseButton1Down:Connect(function() d2 = true end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d2 = false end end)
                RunService.Heartbeat:Connect(function()
                    if not d2 then return end
                    local s2 = math.clamp((UserInputService:GetMouseLocation().X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
                    local nv2 = math.round(s2 * mc)
                    fl.Size = UDim2.new(s2,0,1,0); kn.Position = UDim2.new(s2,-5,0.5,-5); vl.Text = tostring(nv2); cb2(nv2)
                end)
            end
            ChanSlider("R", 8,  r, 255, Color3.fromRGB(230,70,70),  function(v) r=v; UpdateColor() end)
            ChanSlider("G", 36, g, 255, Color3.fromRGB(60,200,80),  function(v) g=v; UpdateColor() end)
            ChanSlider("B", 64, b, 255, Color3.fromRGB(70,130,230), function(v) b=v; UpdateColor() end)
            prev.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(picker, TweenInfo.new(isOpen and 0.24 or 0.18, Enum.EasingStyle.Quart), { Size = UDim2.new(0,210,0,isOpen and 104 or 0) })
            end)
            local A = {}
            function A:Set(c3) color = c3; prev.BackgroundColor3 = c3 end
            function A:Get()   return color end
            return A
        end

        return Tab
    end

    -- Show window
    if wc.IntroEnabled then
        main.Visible = false
        task.spawn(function()
            local s, e = pcall(PlayIntro, wc.IntroText, function()
                main.Visible = true
                Tween(main, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { GroupTransparency = 0 })
            end)
            if not s then
                warn("AlbizaLib Intro Error: " .. tostring(e))
                main.Visible = true
                main.GroupTransparency = 0
            end
        end)
    else
        Tween(main, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { GroupTransparency = 0 })
    end

    return Win
end

