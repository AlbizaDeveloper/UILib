        Parent               = sg,
        Size                 = UDim2.new(1,0,1,0),
        BackgroundColor3     = Color3.fromRGB(0,0,0),
        BackgroundTransparency = 0,
        ZIndex               = 100,
    })
    AddGrad(bg, Color3.fromRGB(5,5,8), Color3.fromRGB(22,4,10), 135)
    CreateSnow(bg, 80)

    -- Glow circle
    local glow = New("Frame", {
        Parent = bg,
        Size   = UDim2.new(0,260,0,260),
        Position = UDim2.new(0.5,-130, 0.5,-130),
        BackgroundColor3 = T.Accent,
        BackgroundTransparency = 0.82,
        BorderSizePixel = 0, ZIndex = 101,
    })
    AddCorner(glow, 1, 0)

    -- Ring
    local ring = New("Frame", {
        Parent = bg, Size = UDim2.new(0,150,0,150),
        Position = UDim2.new(0.5,-75, 0.5,-115),
        BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 102,
    })
    AddCorner(ring, 1, 0)
    local rStroke = AddStroke(ring, T.Accent, 3)

    local logoLbl = New("TextLabel", {
        Parent = ring, Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, Text = "A",
        TextColor3 = T.Accent, TextSize = 85, Font = Enum.Font.GothamBold,
        TextTransparency = 1, ZIndex = 103,
    })
    local titleLbl = New("TextLabel", {
        Parent = bg, Size = UDim2.new(0,440,0,50),
        Position = UDim2.new(0.5,-220, 0.5,55),
        BackgroundTransparency = 1, Text = text or "Albiza Hub",
        TextColor3 = T.Text, TextSize = 28, Font = Enum.Font.GothamBold,
        TextTransparency = 1, ZIndex = 102,
    })
    local subLbl = New("TextLabel", {
        Parent = bg, Size = UDim2.new(0,440,0,24),
        Position = UDim2.new(0.5,-220, 0.5,110),
        BackgroundTransparency = 1, Text = "Loading, please wait...",
        TextColor3 = T.Accent, TextSize = 13, Font = Enum.Font.Gotham,
        TextTransparency = 1, ZIndex = 102,
    })

    -- Loading bar
    local barBG = New("Frame", {
        Parent = bg, Size = UDim2.new(0,300,0,4),
        Position = UDim2.new(0.5,-150, 0.5,150),
        BackgroundColor3 = Color3.fromRGB(28,28,40),
        BackgroundTransparency = 0.3, BorderSizePixel = 0, ZIndex = 102,
    })
    AddCorner(barBG, 1, 0)
    local barFill = New("Frame", {
        Parent = barBG, Size = UDim2.new(0,0,1,0),
        BackgroundColor3 = T.Accent, BorderSizePixel = 0, ZIndex = 103,
    })
    AddCorner(barFill, 1, 0)
    AddGrad(barFill, T.AccentDark, T.AccentGlow, 90)

    -- Glow pulse
    local glowAnim = Tween(glow,
        TweenInfo.new(1.3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
        { Size = UDim2.new(0,340,0,340), Position = UDim2.new(0.5,-170,0.5,-170), BackgroundTransparency = 0.88 })

    -- Ring flicker
    local angle = 0
    local spinC
    spinC = RunService.Heartbeat:Connect(function(dt)
        angle = (angle + 95*dt) % 360
        rStroke.Transparency = 0.15 + math.abs(math.sin(math.rad(angle))) * 0.55
    end)

    local eOut = TweenInfo.new(0.55, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    task.wait(0.25)
    Tween(logoLbl,  eOut, { TextTransparency = 0 }); task.wait(0.35)
    Tween(titleLbl, eOut, { TextTransparency = 0 }); task.wait(0.2)
    Tween(subLbl,   eOut, { TextTransparency = 0 }); task.wait(0.2)
    Tween(barFill, TweenInfo.new(1.9, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
        { Size = UDim2.new(1,0,1,0) })
    task.wait(2.05)
    subLbl.Text = "Ready!"; task.wait(0.4)

    spinC:Disconnect(); glowAnim:Cancel()
    local fOut = TweenInfo.new(0.65, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    for _, d in ipairs(bg:GetDescendants()) do
        if d:IsA("TextLabel") then Tween(d, TweenInfo.new(0.4), { TextTransparency = 1 }) end
        if d:IsA("Frame")     then Tween(d, TweenInfo.new(0.5), { BackgroundTransparency = 1 }) end
    end
    Tween(bg, fOut, { BackgroundTransparency = 1 })
    task.wait(0.72); sg:Destroy()
    if cb then cb() end
end

