        -- Slider ───────────────────────────────────────────────────────────
        function Tab:AddSlider(c2)
            c2 = c2 or {}
            local sc = {
                Title     = c2.Title       or "Slider",
                Desc      = c2.Description or "",
                Min       = c2.Min         or 0,
                Max       = c2.Max         or 100,
                Default   = c2.Default     or 50,
                Increment = c2.Increment   or 1,
                Suffix    = c2.Suffix      or "",
                Callback  = c2.Callback    or function() end,
            }
            local val = math.clamp(sc.Default, sc.Min, sc.Max)
            local elem = New("Frame", {
                Parent = page, Size = UDim2.new(1,0,0,64),
                BackgroundColor3 = T.Surface, BackgroundTransparency = 0.1,
                BorderSizePixel = 0, ZIndex = 5, LayoutOrder = O(),
            })
