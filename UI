                local mx = UserInputService:GetMouseLocation().X
                local s  = math.clamp((mx - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local nv = S2V(s)
                if nv ~= val then Render(nv) end
            end)
            local A = {}
            function A:Set(v) v = math.clamp(v,sc.Min,sc.Max); Render(v); task.spawn(sc.Callback,v) end
            function A:Get() return val end
            return A
        end

